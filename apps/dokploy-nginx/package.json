    "stack:destroy": "alchemy destroy --yes",
    "diff": "alchemy deploy --dry-run"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "alambic": "workspace:*",
    "alchemy": "catalog:",
    "dotenv": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "~6.0.2"
  }
}
